# Copy this file to .env.local for local overrides. All variables are
# optional — the site works out of the box with the defaults in
# src/config/site.ts.

# Public production URL used for canonical links, Open Graph/Twitter images,
# sitemap.xml, robots.txt and JSON-LD structured data. Match whichever URL
# the deployment is actually served from.
NEXT_PUBLIC_SITE_URL=https://xenoframes008.github.io/careerprofile

# Path prefix when the site is hosted under a subdirectory (GitHub Pages
# project sites are served at /<repo>/). Leave empty for a custom-domain apex
# (e.g. https://atanusamadder.dev). The GitHub Actions workflow sets this
# automatically for Pages deploys.
NEXT_PUBLIC_BASE_PATH=/careerprofile
